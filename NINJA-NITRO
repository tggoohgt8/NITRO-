def send_to_webhook(webhook_url, result):
    """Send valid code to Discord webhook"""
    try:
        embed = {
            "embeds": [{
                "title": "🎯 VALID NITRO CODE FOUND!",
                "color": 0x00ff00,
                "fields": [
                    {"name": "🔗 Link", "value": f"[Click Here](https://discord.com/gifts/{result['code']})", "inline": False},
                    {"name": "📝 Code", "value": f"`{result['code']}`", "inline": True},
                    {"name": "📦 Type", "value": result.get('type', 'Unknown'), "inline": True},
                    {"name": "⏳ Duration", "value": result.get('duration', 'Unknown'), "inline": True},
                    {"name": "📅 Expires", "value": result.get('expires_at', 'Unknown'), "inline": False},
                    {"name": "🔒 Claimed", "value": "✅ Yes" if result.get('claimed') else "❌ No", "inline": True}
                ],
                "footer": {
                    "text": f"{COPYRIGHT} | {AUTHOR} | {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"
                }
            }]
        }
        
        response = requests.post(
            webhook_url,
            json=embed,
            headers={"Content-Type": "application/json"},
            timeout=10
        )
        return response.status_code in [200, 204]
    except:
        return False

