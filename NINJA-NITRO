class NinjaNitro:
    """Main engine for generating and checking Nitro codes"""
    
    def __init__(self):
        self.generator = NitroGenerator()
        self.checker = NitroChecker()
        self.results = {'valid': [], 'invalid': []}
        self.total_generated = 0
        self.total_checked = 0
        self.running = True
    
    def generate_and_check(self, count, threads=10, webhook=None, callback=None):
        """Generate and check Nitro codes"""
        self.running = True
        
        print(f"\n{col(Colors.BLUE, '[*]')} Generating {count} Nitro codes...")
        
        # Generate codes
        codes = self.generator.generate_batch(count)
        self.total_generated = len(codes)
        
        print(f"{col(Colors.GREEN, '[+]')} Generated {len(codes)} codes")
        print(f"{col(Colors.BLUE, '[*]')} Checking codes with {threads} threads...\n")
        
        # Check codes
        def progress_callback(checked, total, result):
            self.total_checked = checked
            if result['valid']:
                self.results['valid'].append(result)
                print(f"\r{col(Colors.GREEN, '[✅]')} Valid: {len(self.results['valid'])} | Invalid: {len(self.results['invalid'])} | Checked: {checked}/{total}   ")
                if webhook:
                    send_to_webhook(webhook, result)
            else:
                self.results['invalid'].append(result)
                if checked % 50 == 0:
                    print(f"\r{col(Colors.CYAN, '[⏳]')} Valid: {len(self.results['valid'])} | Invalid: {len(self.results['invalid'])} | Checked: {checked}/{total}   ", end='')
        
        self.results = self.checker.check_batch(codes, threads, progress_callback)
        print()  # New line after progress
        
        return self.results
    
    def generate_gift_links(self, count):
        """Generate gift links only"""
        codes = self.generator.generate_batch(count)
        links = [self.generator.generate_gift_link(code) for code in codes]
        return links
    
    def check_single_code(self, code):
        """Check a single Nitro code"""
        return self.checker.check_code(code)

