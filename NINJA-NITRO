# ================================================================
#  NITRO CODE GENERATOR
# ================================================================
class NitroGenerator:
    """Generate Discord Nitro gift codes"""
    
    @staticmethod
    def generate(length=16):
        """Generate random Nitro code"""
        chars = string.ascii_letters + string.digits
        return ''.join(random.choices(chars, k=length))
    
    @staticmethod
    def generate_gift_link(code):
        """Create gift link from code"""
        return f"https://discord.com/gifts/{code}"
    
    @staticmethod
    def generate_batch(count, length=16):
        """Generate multiple codes"""
        codes = []
        seen = set()
        while len(codes) < count:
            code = NitroGenerator.generate(length)
            if code not in seen:
                seen.add(code)
                codes.append(code)
        return codes

# ================================================================
#  NITRO CHECKER
# ================================================================
class NitroChecker:
    """Check Discord Nitro code validity"""
    
    API_URL = "https://discord.com/api/v9/entitlements/gift-codes/{code}?with_application=false&with_subscription_plan=true"
    
    @staticmethod
    def check_code(code):
        """Check if Nitro code is valid"""
        try:
            url = NitroChecker.API_URL.format(code=code)
            headers = {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
                "Accept": "application/json",
                "Accept-Language": "en-US,en;q=0.9"
            }
            
            response = requests.get(url, headers=headers, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                if data.get('uses') is not None:
                    # Valid code
                    subscription = data.get('subscription_plan', {})
                    return {
                        'valid': True,
                        'code': code,
                        'type': subscription.get('name', 'Nitro'),
                        'duration': subscription.get('duration', 'Unknown'),
                        'claimed': data.get('claimed', False),
                        'expires_at': data.get('expires_at', 'Unknown')
                    }
                else:
                    return {'valid': False, 'code': code, 'reason': 'Invalid format'}
            elif response.status_code == 404:
                return {'valid': False, 'code': code, 'reason': 'Code not found'}
            elif response.status_code == 429:
                return {'valid': False, 'code': code, 'reason': 'Rate limited'}
            else:
                return {'valid': False, 'code': code, 'reason': f'HTTP {response.status_code}'}
                
        except requests.exceptions.Timeout:
            return {'valid': False, 'code': code, 'reason': 'Timeout'}
        except requests.exceptions.ConnectionError:
            return {'valid': False, 'code': code, 'reason': 'Connection error'}
        except Exception as e:
            return {'valid': False, 'code': code, 'reason': str(e)}
    
    @staticmethod
    def check_batch(codes, threads=10, callback=None):
        """Check multiple codes with threading"""
        results = {'valid': [], 'invalid': []}
        lock = threading.Lock()
        checked = 0
        
        def worker(code):
            nonlocal checked
            result = NitroChecker.check_code(code)
            with lock:
                checked += 1
                if result['valid']:
                    results['valid'].append(result)
                else:
                    results['invalid'].append(result)
                if callback:
                    callback(checked, len(codes), result)
        
        threads_list = []
        for code in codes:
            t = threading.Thread(target=worker, args=(code,))
            t.daemon = True
            t.start()
            threads_list.append(t)
            if len(threads_list) >= threads:
                for t in threads_list:
                    t.join(timeout=0.1)
                threads_list = []
        
        for t in threads_list:
            t.join()
        
        return results

